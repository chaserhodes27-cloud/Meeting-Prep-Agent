ANTHROPIC_API_KEY=sk-ant-your-key-here
TAVILY_API_KEY=tvly-your-key-here
SECRET_KEY=generate-with-python-secrets-token-hex-32
DATABASE_URL=sqlite:///meeting_prep.db

# Email via Gmail SMTP (for password reset + briefing emails)
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: SendGrid for briefing delivery emails
SENDGRID_API_KEY=SG.your-key-here
FROM_EMAIL=you@yourdomain.com

# Google Calendar — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5001/oauth2callback
